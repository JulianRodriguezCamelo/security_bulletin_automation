# ── API Keys ────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
VT_API_KEY=<tu-api-key-virustotal>
TENABLE_ACCESS_KEY=<tu-access-key-tenable>
TENABLE_SECRET_KEY=<tu-secret-key-tenable>
NVD_API_KEY=<opcional-nvd-api-key>

# ── Correo entrante (IMAP) ───────────────────────────────────────────
EMAIL_HOST=outlook.office365.com
EMAIL_USER=tu@empresa.com
EMAIL_PASS=<tu-password>

# ── Correo saliente (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
REPORT_TO_EMAIL=soc@empresa.com
REPORT_FROM_EMAIL=tu@empresa.com
REPORT_EMAIL_PASS=<tu-password>
DISABLE_EMAIL=true

# ── Configuración de la aplicación ──────────────────────────────────
COMPANY_TECHS=Google Chrome,Windows,Fortinet,Oracle,WordPress
DATA_DIR=./data

# URLs de tus servidores a escanear (separadas por coma).
# Al procesar un boletín, el sistema detecta el stack tecnológico de cada URL
# y lo cruza con los CVEs del boletín para saber si algún servidor propio es vulnerable.
# Ejemplo: WAPP_EXTRA_URLS=https://srv-web01.empresa.com,https://intranet.empresa.com,https://10.0.1.50
WAPP_EXTRA_URLS=
WAPP_TIMEOUT=30

# ── Inventario interno de activos (CMDB) ───────────────────────────
# API que expone el inventario de servidores. Al procesar un boletín,
# el sistema cruza CVEs y SO afectados contra este inventario.
ASSET_INVENTORY_API_KEY=<api-key-inventario>
ASSET_INVENTORY_URL=http://172.16.0.216/api/external
SECRET_KEY=<genera-una-clave-segura-con-python-secrets.token_hex-32>

# ── CORS (orígenes permitidos para el API Flask) ─────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Oracle 21c ───────────────────────────────────────────────────────
# Activar con USE_ORACLE=true para usar Oracle en lugar de YAML/Excel
USE_ORACLE=false
ORACLE_USER=caronte
ORACLE_PASSWORD=<contraseña-segura>
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
