# ─────────────────────────────────────────────────────────────
# Streamlit Cloud → Settings → Secrets → pega el contenido
# de este archivo (sin la extensión .example) con tus valores.
# ─────────────────────────────────────────────────────────────

# API Keys
GROQ_API_KEY      = "gsk_..."
VT_API_KEY        = "..."
NVD_API_KEY       = ""

# Tenable (opcional)
TENABLE_ACCESS_KEY = ""
TENABLE_SECRET_KEY = ""

# Email (opcional)
EMAIL_HOST = "imap.gmail.com"
EMAIL_USER = ""
EMAIL_PASS = ""
SMTP_HOST  = "smtp.gmail.com"
SMTP_PORT  = "587"

# Reporte por email (opcional)
REPORT_TO_EMAIL   = ""
REPORT_FROM_EMAIL = ""
REPORT_EMAIL_PASS = ""

# Web fingerprinting (opcional)
WAPP_EXTRA_URLS = ""
WAPP_TIMEOUT    = "30"
COMPANY_TECHS   = "Windows,Fortinet,Oracle,WordPress,Red Hat,Ubuntu"

# ── Persistencia en GitHub ────────────────────────────────────
# Crea un Personal Access Token en:
# GitHub → Settings → Developer settings → Personal access tokens
# Permisos necesarios: repo (Contents: Read & Write)
GITHUB_TOKEN      = "ghp_..."
GITHUB_REPO       = "tu-usuario/tu-repo"          # ej. "julian/security-bulletins"
GITHUB_EXCEL_PATH = "data/Informe_Amenazas.xlsx"
GITHUB_BRANCH     = "main"

# ── Usuarios de la app ────────────────────────────────────────
# Genera este bloque ejecutando: python setup_auth.py
# Luego copia el contenido completo de auth_config.yaml aquí
# entre las comillas triple (respetando la indentación YAML).
auth_config_yaml = """
credentials:
  usernames:
    julian:
      email: tu@email.com
      name: Julian Rodriguez
      password: $2b$12$...hash_generado_por_setup_auth...
    colega:
      email: colega@email.com
      name: Nombre Colega
      password: $2b$12$...hash_generado_por_setup_auth...
cookie:
  expiry_days: 7
  key: clave_hex_de_64_caracteres_generada_por_setup_auth
  name: sec_bulletin_auth
"""
