# Email Settings
EMAIL_HOST=imap.gmail.com
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# API Keys
ANTHROPIC_API_KEY=tu_claude_api_key
VT_API_KEY=tu_virustotal_api_key

# Tenable Vulnerability Management (cloud.tenable.com)
TENABLE_ACCESS_KEY=tu_tenable_access_key
TENABLE_SECRET_KEY=tu_tenable_secret_key

# NVD API (optional – increases rate limit from 5/30s to 50/30s)
# Request a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Wappalyzer: additional URLs to fingerprint (comma-separated)
# Tenable assets are fetched automatically; add internal/extra URLs here
WAPP_EXTRA_URLS=https://portal.empresa.com,https://intranet.empresa.com
WAPP_TIMEOUT=30

# Application Settings
COMPANY_TECHS=Google Chrome,Windows,Fortinet,Oracle,WordPress,Red Hat,Ubuntu
DATA_DIR=./data
